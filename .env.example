# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SESSION_STYLE=ga
OPENAI_ANALYSIS_MODEL=gpt-5.5
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-token
TWILIO_FROM_NUMBER=+13334445555

# Assessment target. The app refuses to call any other number.
TARGET_TEST_NUMBER=+18054398008

# Public URL for this FastAPI service. Use ngrok or another HTTPS tunnel.
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=https://your-public-host.example

# Optional runtime tuning
ARTIFACTS_DIR=artifacts
INITIAL_GREETING_DELAY_MS=1200
RUN_SUITE_SPACING_SECONDS=45
MAX_CALL_SECONDS=180
